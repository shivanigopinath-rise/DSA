import java.util.Scanner;
class Main{
    static int findnthTerm(int n){
        int sum=0,term=0;
        for(int i=1;i<=n;i++){
            sum=sum+i;
            term=term+sum;
        }
        return term;
    }
    
    public static void main(String[]args)
    {
        Scanner scan=new Scanner(System.in);
        System.out.println("enter n:");
        int n=scan.nextInt();
        int  sum=findnthTerm( n);
        System.out.println("sum of first " + n + " natural term is: " +sum);
    }
    }
